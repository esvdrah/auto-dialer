# Example .env file for Auto Dialer application

# Your DNI/RUT number without dots or hyphen
DNI_NUMBER=99999999

# Base URL for the Buk API (optional, this is the default value)
BASE_DIAL_URL=https://app.ctrlit.cl/ctrl/dial/

# Entry schedules (cron format)
# 08:00 and 14:00 from Monday to Friday
SCHEDULE_ENTRY=0 8 * * 1-5,0 14 * * 1-5

# Exit schedules (cron format)
# 13:00 and 18:00 from Monday to Friday
SCHEDULE_EXIT=0 13 * * 1-5,0 18 * * 1-5
